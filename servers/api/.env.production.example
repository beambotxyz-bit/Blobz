NODE_ENV=production
PORT=8787

DATABASE_URL=postgres://blobz_app:replace-db-password@127.0.0.1:5432/blobz
DATABASE_SSL=0
DB_POOL_MAX=30

TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400

SESSION_SECRET=replace-with-64-plus-random-chars
SESSION_TTL_SECONDS=604800

INTERNAL_API_TOKEN=replace-with-64-plus-random-chars
# Prefer ADMIN_TOKEN_HASH in production. Generate with:
# node -e "console.log(require('crypto').createHash('sha256').update(process.argv[1]).digest('hex'))" "your-admin-token"
ADMIN_TOKEN_HASH=replace-with-sha256-of-admin-token

CORS_ORIGINS=https://your-game-domain.example
API_PUBLIC_BASE=https://your-api-domain.example
CLIENT_PUBLIC_BASE=https://your-game-domain.example

WORLD_BASE_PORT=10000
WORLD_WS_HOST=your-game-ws-domain.example
WORLD_WS_PROTOCOL=wss
WORLD_SUPERVISOR_ENABLED=1
WORLD_SUPERVISOR_INTERVAL_MS=5000
WORLD_SUPERVISOR_SHUTDOWN_MS=5000

GAME_SERVER_CWD=../agarv1/src
GAME_SERVER_ENTRY=index.js
GAME_SERVER_LOG_DIR=../../output/worlds
# Use 127.0.0.1 when Nginx/Caddy terminates public WSS and proxies to local game ports.
GAME_SERVER_BIND_HOST=127.0.0.1
