{
  "name": "blobz",
  "version": "1.0.0",
  "description": "Blobz browser arena game base",
  "main": "index.js",
  "dependencies": {
    "burrow": "0.0.0",
    "finalhandler": "^0.3.6",
    "serve-static": "^1.9.3",
    "ws": "latest",
    "asyncconsole": "latest"
  },
  "devDependencies": {},
  "scripts": {
    "start": "node server/index.js",
    "client:start": "node server/index.js",
    "api:start": "npm --prefix servers/api start",
    "api:migrate": "npm --prefix servers/api run migrate",
    "api:check": "npm --prefix servers/api run check",
    "prod:check": "node --check server/index.js && node --check ecosystem.config.cjs && npm run api:check",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beambotxyz-bit/Blobz.git"
  },
  "author": "Blobz Team",
  "license": "Apache License 2.0",
  "bugs": {
    "url": "https://github.com/beambotxyz-bit/Blobz/issues"
  },
  "homepage": "https://github.com/beambotxyz-bit/Blobz"
}
